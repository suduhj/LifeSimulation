{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://life-simulator.local/schemas/ai-event-response.schema.json",
  "title": "Life Simulator AI Event Response",
  "description": "Reference schema for an AI-proposed life event. The engine must validate and authorize the state patch before applying it.",
  "type": "object",
  "required": [
    "schemaVersion",
    "responseType",
    "worldId",
    "runId",
    "turnId",
    "timeSpan",
    "selectedSeeds",
    "playerText",
    "event",
    "choices",
    "freeform",
    "visibleChanges",
    "statePatch",
    "internal"
  ],
  "properties": {
    "schemaVersion": {
      "const": "mvp.ai_event_response.v1"
    },
    "responseType": {
      "enum": [
        "life_event",
        "action_resolution",
        "clarification_request",
        "forced_consequence",
        "ending_summary",
        "memory_update",
        "json_repair"
      ]
    },
    "worldId": {
      "enum": ["cultivation", "cthulhu", "wasteland"]
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "turnId": {
      "type": "string",
      "minLength": 1
    },
    "timeSpan": {
      "type": "object",
      "required": ["ageStart", "ageEnd", "yearsElapsed", "pace"],
      "properties": {
        "ageStart": { "type": "number", "minimum": 0 },
        "ageEnd": { "type": "number", "minimum": 0 },
        "yearsElapsed": { "type": "number", "minimum": 0 },
        "pace": { "enum": ["single_event", "yearly", "multi_year", "scene_moment"] },
        "paceReasonKey": { "type": "string" }
      },
      "additionalProperties": true
    },
    "selectedSeeds": {
      "type": "array",
      "minItems": 0,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["poolType", "seedId", "adaptationRole"],
        "properties": {
          "poolType": {
            "enum": ["identity_seed", "talent_seed", "npc_template_seed", "event_seed", "faction_seed", "location_seed", "ending_seed", "world_rule_seed"]
          },
          "seedId": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "adaptationRole": {
            "enum": ["primary", "secondary", "constraint", "foreshadowing", "contrast"]
          }
        },
        "additionalProperties": true
      }
    },
    "interactionMode": {
      "enum": ["playable_choices", "freeform_confirmation", "non_interactive", "ending", "system_only"]
    },
    "engineCheck": {
      "type": "object",
      "properties": {
        "providedByEngine": { "type": "boolean" },
        "checkResult": {
          "enum": ["critical_failure", "failure", "partial_success", "success", "great_success", "not_applicable", "unknown"]
        },
        "riskLevel": {
          "enum": ["safe", "low", "medium", "high", "extreme", "unknown"]
        },
        "difficultyLabel": { "type": "string" }
      },
      "additionalProperties": true
    },
    "playerText": {
      "type": "object",
      "required": ["title", "body", "visibleChanges"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "body": { "type": "string", "minLength": 1 },
        "visibleChanges": {
          "type": "array",
          "items": { "type": "string" }
        },
        "relationshipSummary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "worldProgressSummary": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "event": {
      "type": "object",
      "required": ["eventId", "lifeStage", "riskLabel", "summaryTags"],
      "properties": {
        "eventId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "lifeStage": {
          "enum": ["birth", "childhood", "adolescence", "youth", "adulthood", "middleAge", "oldAge"]
        },
        "riskLabel": {
          "enum": ["safe", "low", "medium", "high", "extreme", "unknown"]
        },
        "summaryTags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      },
      "additionalProperties": true
    },
    "choices": {
      "type": "array",
      "minItems": 0,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "text", "intentTags", "fuzzySuccessLabel", "riskLabel"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^choice_[1-3]$"
          },
          "text": {
            "type": "string",
            "minLength": 12
          },
          "intentTags": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            }
          },
          "fuzzySuccessLabel": {
            "type": "string",
            "minLength": 1
          },
          "riskLabel": {
            "enum": ["safe", "low", "medium", "high", "extreme", "unknown"]
          }
        },
        "additionalProperties": true
      }
    },
    "visibleChanges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target", "text"],
        "properties": {
          "type": {
            "enum": [
              "attribute",
              "manifestation",
              "exposure",
              "relationship",
              "npc",
              "faction",
              "progression",
              "world_state",
              "status",
              "memory",
              "score",
              "item",
              "other"
            ]
          },
          "target": { "type": "string", "minLength": 1 },
          "amount": { "type": "number" },
          "currentValue": {},
          "source": { "type": "string" },
          "duration": {
            "enum": ["instant", "temporary", "permanent", "recoverable", "unknown"]
          },
          "recoveryCondition": { "type": "string" },
          "text": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "freeform": {
      "type": "object",
      "required": ["allowed", "clarificationNeeded", "riskBand", "judgmentFactors"],
      "properties": {
        "allowed": { "type": "boolean" },
        "clarificationNeeded": { "type": "boolean" },
        "interpretedAction": { "type": "string" },
        "riskBand": {
          "enum": ["safe", "low", "medium", "high", "extreme", "world_breaking", "unknown"]
        },
        "fuzzySuccessLabel": { "type": "string" },
        "judgmentFactors": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "statePatch": {
      "type": "object",
      "required": [
        "attributeChanges",
        "manifestationChanges",
        "exposureChanges",
        "relationshipChanges",
        "importantNPCUpdates",
        "factionChanges",
        "progressionChanges",
        "worldStateChanges",
        "memoryUpdates",
        "scoreDelta"
      ],
      "properties": {
        "attributeChanges": { "type": "array" },
        "manifestationChanges": { "type": "array" },
        "exposureChanges": { "type": "array" },
        "relationshipChanges": { "type": "array" },
        "importantNPCUpdates": { "type": "array" },
        "factionChanges": { "type": "array" },
        "progressionChanges": { "type": "array" },
        "worldStateChanges": { "type": "array" },
        "memoryUpdates": { "type": "array" },
        "scoreDelta": { "type": "number" }
      },
      "additionalProperties": true
    },
    "internal": {
      "type": "object",
      "required": ["judgmentSummary", "validationFlags", "hiddenStateNotes"],
      "properties": {
        "judgmentSummary": { "type": "string" },
        "validationFlags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "hiddenStateNotes": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
